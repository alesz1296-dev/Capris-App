{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm install && npm --workspace @capris/shared run build && npm --workspace apps/web run build",
    "watchPatterns": [
      "/apps/web/**",
      "/packages/shared/**",
      "/package.json",
      "/package-lock.json",
      "/tsconfig.base.json"
    ]
  },
  "deploy": {
    "startCommand": "npm --workspace apps/web run start",
    "healthcheckPath": "/",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
