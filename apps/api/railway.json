{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm install && npm --workspace @capris/shared run build && npm --workspace apps/api run build",
    "watchPatterns": [
      "/apps/api/**",
      "/packages/shared/**",
      "/package.json",
      "/package-lock.json",
      "/tsconfig.base.json"
    ]
  },
  "deploy": {
    "startCommand": "npm --workspace apps/api run start",
    "healthcheckPath": "/api/v1/system-health",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "environments": {
    "staging": {
      "deploy": {
        "startCommand": "npm --workspace apps/api run start"
      }
    }
  }
}
