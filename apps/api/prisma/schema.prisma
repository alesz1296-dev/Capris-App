generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Organization {
  id            String            @id
  name          String
  defaultLocale String
  timezone      String
  active        Boolean           @default(true)
  users         User[]
  teams         Team[]
  scopes        SupervisorScope[]
  provinces     Province[]
  zones         Zone[]
  clients       Client[]
  pointsOfSale  PointOfSale[]
  activityTypes ActivityType[]
  taskTypes     TaskType[]
  workflowRules WorkflowRule[]
  tasks         Task[]
  visits        Visit[]
  mediaAssets   MediaAsset[]
  evidencePhotos EvidencePhoto[]
  comments      Comment[]
  observations  Observation[]
  consignations Consignation[]
  activations   Activation[]
  exhibitions   ExhibitionInstallation[]
  agendaEvents  AgendaEvent[]
  clientRequests ClientRequest[]
  exceptions    ExceptionRecord[]
  reportSnapshots ReportSnapshot[]
  reminderRules ReminderRule[]
  adminSettings AdminSettings?
  sessions      DeviceSession[]
}

model User {
  id             String            @id
  organizationId String
  name           String
  email          String            @unique
  role           String
  locale         String
  active         Boolean           @default(true)
  googleSubject  String?           @unique
  avatarUrl      String?
  lastLoginAt    DateTime?
  organization   Organization      @relation(fields: [organizationId], references: [id])
  leadingTeams   Team[]            @relation("TeamLead")
  scopes         SupervisorScope[]
  requestedTasks Task[]            @relation("TaskRequester")
  assignedTasks  Task[]            @relation("TaskAssignee")
  visits         Visit[]
  mediaAssets    MediaAsset[]
  evidencePhotos EvidencePhoto[]
  comments       Comment[]
  observations   Observation[]
  consignations  Consignation[]
  activations    Activation[]
  exhibitions    ExhibitionInstallation[]
  ownedAgendaEvents AgendaEvent[]     @relation("AgendaEventOwner")
  createdAgendaEvents AgendaEvent[]   @relation("AgendaEventCreator")
  ownedClientRequests ClientRequest[] @relation("ClientRequestOwner")
  submittedExceptions ExceptionRecord[] @relation("ExceptionSubmittedBy")
  reviewedExceptions ExceptionRecord[]  @relation("ExceptionReviewedBy")
  sessions       DeviceSession[]
}

model DeviceSession {
  id               String       @id
  organizationId   String
  userId           String
  provider         String
  deviceName       String?
  refreshTokenHash String       @unique
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  lastUsedAt       DateTime?
  organization     Organization @relation(fields: [organizationId], references: [id])
  user             User         @relation(fields: [userId], references: [id])

  @@index([userId, revokedAt])
  @@index([organizationId, expiresAt])
}

model Team {
  id             String       @id
  organizationId String
  name           String
  leadUserId     String?
  active         Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id])
  leadUser       User?        @relation("TeamLead", fields: [leadUserId], references: [id])
  agendaEvents   AgendaEvent[]
}

model SupervisorScope {
  id             String       @id
  organizationId String
  userId         String
  type           String
  referenceId    String
  referenceName  String
  active         Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([userId, organizationId, type, referenceId])
}

model Province {
  id             String       @id
  organizationId String
  country        String
  name           String
  code           String
  active         Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id])
  zones          Zone[]
  pointsOfSale   PointOfSale[]
  tasks          Task[]
  visits         Visit[]
  clientRequests ClientRequest[]

  @@unique([organizationId, code])
}

model Zone {
  id             String       @id
  organizationId String
  provinceId     String
  name           String
  code           String
  active         Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id])
  province       Province     @relation(fields: [provinceId], references: [id])
  pointsOfSale   PointOfSale[]
  tasks          Task[]
  visits         Visit[]
  clientRequests ClientRequest[]

  @@unique([organizationId, code])
}

model Client {
  id             String       @id
  organizationId String
  name           String
  code           String
  contactEmail   String?
  active         Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id])
  pointsOfSale   PointOfSale[]
  tasks          Task[]
  clientRequests ClientRequest[]

  @@unique([organizationId, code])
}

model PointOfSale {
  id             String       @id
  organizationId String
  provinceId     String
  zoneId         String
  clientId       String
  name           String
  code           String
  address        String?
  latitude       Float?
  longitude      Float?
  active         Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id])
  province       Province     @relation(fields: [provinceId], references: [id])
  zone           Zone         @relation(fields: [zoneId], references: [id])
  client         Client       @relation(fields: [clientId], references: [id])
  tasks          Task[]
  visits         Visit[]
  activations    Activation[]
  exhibitions    ExhibitionInstallation[]
  clientRequests ClientRequest[]

  @@unique([organizationId, code])
}

model ActivityType {
  id             String         @id
  organizationId String
  name           String
  code           String
  active         Boolean        @default(true)
  organization   Organization   @relation(fields: [organizationId], references: [id])
  workflowRules  WorkflowRule[]
  tasks          Task[]

  @@unique([organizationId, code])
}

model TaskType {
  id             String         @id
  organizationId String
  name           String
  code           String
  active         Boolean        @default(true)
  organization   Organization   @relation(fields: [organizationId], references: [id])
  workflowRules  WorkflowRule[]
  tasks          Task[]

  @@unique([organizationId, code])
}

model WorkflowRule {
  id                         String        @id
  organizationId             String
  taskTypeId                 String?
  activityTypeId             String?
  requiresBeforePhoto        Boolean       @default(true)
  requiresAfterPhoto         Boolean       @default(true)
  requiresGps                Boolean       @default(true)
  requiresComment            Boolean       @default(false)
  requiresSupervisorApproval Boolean       @default(false)
  requiresConsignationEmail  Boolean       @default(false)
  organization               Organization  @relation(fields: [organizationId], references: [id])
  taskType                   TaskType?     @relation(fields: [taskTypeId], references: [id])
  activityType               ActivityType? @relation(fields: [activityTypeId], references: [id])
}

model Task {
  id             String       @id
  organizationId String
  title          String
  requesterId    String
  assigneeId     String
  scheduledFor   String
  provinceId     String
  zoneId         String
  clientId       String?
  pointOfSaleId  String?
  activityTypeId String
  taskTypeId     String
  status         String
  priority       String
  difficulty     String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  requester      User         @relation("TaskRequester", fields: [requesterId], references: [id])
  assignee       User         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  province       Province     @relation(fields: [provinceId], references: [id])
  zone           Zone         @relation(fields: [zoneId], references: [id])
  client         Client?      @relation(fields: [clientId], references: [id])
  pointOfSale    PointOfSale? @relation(fields: [pointOfSaleId], references: [id])
  activityType   ActivityType @relation(fields: [activityTypeId], references: [id])
  taskType       TaskType     @relation(fields: [taskTypeId], references: [id])
  visits         Visit[]
  evidencePhotos EvidencePhoto[]
  comments       Comment[]
  observations   Observation[]
  consignations  Consignation[]
  activations    Activation[]
  exhibitions    ExhibitionInstallation[]
  clientRequests ClientRequest[]
  exceptions     ExceptionRecord[]

  @@index([organizationId, scheduledFor])
  @@index([organizationId, assigneeId, status])
}

model Visit {
  id                 String       @id
  organizationId     String
  taskId             String
  assigneeId         String
  scheduledFor       String
  provinceId         String
  zoneId             String
  pointOfSaleId      String?
  status             String
  checkedInAt        String?
  checkedInLatitude  Float?
  checkedInLongitude Float?
  checkedOutAt       String?
  checkedOutLatitude Float?
  checkedOutLongitude Float?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  organization        Organization  @relation(fields: [organizationId], references: [id])
  task                Task          @relation(fields: [taskId], references: [id])
  assignee            User          @relation(fields: [assigneeId], references: [id])
  province            Province      @relation(fields: [provinceId], references: [id])
  zone                Zone          @relation(fields: [zoneId], references: [id])
  pointOfSale         PointOfSale?  @relation(fields: [pointOfSaleId], references: [id])
  evidencePhotos      EvidencePhoto[]
  consignations       Consignation[]
  activations         Activation[]
  exhibitions         ExhibitionInstallation[]
  clientRequests      ClientRequest[]
  exceptions          ExceptionRecord[]

  @@index([organizationId, scheduledFor])
  @@index([assigneeId, status])
}

model MediaAsset {
  id                   String        @id
  organizationId       String
  uploaderUserId       String
  fileName             String
  mimeType             String
  originalStoragePath  String
  thumbnailStoragePath String?
  capturedAt           String
  uploadStatus         String
  syncState            String        @default("synced")
  uploadSessionId      String?
  uploadProgress       Float         @default(100)
  retryCount           Int           @default(0)
  lastError            String?
  chunkCount           Int?
  uploadedChunkCount   Int?
  byteSize             Int?
  width                Int?
  height               Int?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  organization         Organization  @relation(fields: [organizationId], references: [id])
  uploader             User          @relation(fields: [uploaderUserId], references: [id])
  evidencePhotos       EvidencePhoto[]
  exceptions           ExceptionRecord[]

  @@index([organizationId, uploadStatus])
}

model EvidencePhoto {
  id             String       @id
  organizationId String
  uploaderUserId String
  taskId         String
  visitId        String?
  mediaAssetId   String
  type           String
  capturedAt     String
  latitude       Float?
  longitude      Float?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  uploader       User         @relation(fields: [uploaderUserId], references: [id])
  task           Task         @relation(fields: [taskId], references: [id])
  visit          Visit?       @relation(fields: [visitId], references: [id])
  mediaAsset     MediaAsset   @relation(fields: [mediaAssetId], references: [id])
  beforeConsignations Consignation[] @relation("ConsignationBeforeEvidence")
  afterConsignations  Consignation[] @relation("ConsignationAfterEvidence")

  @@index([taskId, type])
  @@index([visitId])
  @@index([organizationId, capturedAt])
}

model Comment {
  id             String       @id
  organizationId String
  taskId         String
  userId         String
  body           String
  createdAt      String
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  task           Task         @relation(fields: [taskId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@index([taskId, createdAt])
  @@index([organizationId, createdAt])
}

model Observation {
  id             String       @id
  organizationId String
  taskId         String
  userId         String
  body           String
  createdAt      String
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  task           Task         @relation(fields: [taskId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@index([taskId, createdAt])
  @@index([organizationId, createdAt])
}

model Consignation {
  id             String       @id
  organizationId String
  taskId         String
  userId         String
  visitId        String?
  note           String?
  status         String
  preparedAt     String
  reviewedAt     String?
  recipientEmails String?
  emailSubject   String?
  emailBody      String?
  beforeEvidenceId String?
  afterEvidenceId String?
  sendFailureReason String?
  failedAt       String?
  sentAt         String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  task           Task         @relation(fields: [taskId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
  visit          Visit?       @relation(fields: [visitId], references: [id])
  beforeEvidence EvidencePhoto? @relation("ConsignationBeforeEvidence", fields: [beforeEvidenceId], references: [id])
  afterEvidence  EvidencePhoto? @relation("ConsignationAfterEvidence", fields: [afterEvidenceId], references: [id])
  exceptions     ExceptionRecord[]

  @@index([taskId, preparedAt])
  @@index([organizationId, status])
}

model Activation {
  id             String       @id
  organizationId String
  taskId         String
  userId         String
  visitId        String?
  pointOfSaleId  String?
  quantity       Int
  note           String?
  recordedAt     String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  task           Task         @relation(fields: [taskId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
  visit          Visit?       @relation(fields: [visitId], references: [id])
  pointOfSale    PointOfSale? @relation(fields: [pointOfSaleId], references: [id])

  @@index([taskId, recordedAt])
  @@index([organizationId, recordedAt])
}

model ExhibitionInstallation {
  id             String       @id
  organizationId String
  taskId         String
  userId         String
  visitId        String?
  pointOfSaleId  String?
  quantity       Int
  note           String?
  recordedAt     String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  task           Task         @relation(fields: [taskId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
  visit          Visit?       @relation(fields: [visitId], references: [id])
  pointOfSale    PointOfSale? @relation(fields: [pointOfSaleId], references: [id])

  @@index([taskId, recordedAt])
  @@index([organizationId, recordedAt])
}

model AgendaEvent {
  id               String       @id
  organizationId   String
  title            String
  description      String?
  startAt          String
  endAt            String
  allDay           Boolean      @default(false)
  scopeType        String
  scopeReferenceId String?
  ownerUserId      String?
  teamId           String?
  colorToken       String?
  createdByUserId  String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  organization     Organization @relation(fields: [organizationId], references: [id])
  owner            User?        @relation("AgendaEventOwner", fields: [ownerUserId], references: [id])
  team             Team?        @relation(fields: [teamId], references: [id])
  createdBy        User         @relation("AgendaEventCreator", fields: [createdByUserId], references: [id])

  @@index([organizationId, startAt])
  @@index([organizationId, scopeType, scopeReferenceId])
}

model ClientRequest {
  id             String       @id
  organizationId String
  title          String
  description    String?
  requesterName  String
  requesterEmail String?
  ownerUserId    String
  clientId       String?
  provinceId     String?
  zoneId         String?
  pointOfSaleId  String?
  taskId         String?
  visitId        String?
  status         String
  dueDate        String
  openedAt       String
  resolvedAt     String?
  closedAt       String?
  priority       String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  owner          User         @relation("ClientRequestOwner", fields: [ownerUserId], references: [id])
  client         Client?      @relation(fields: [clientId], references: [id])
  province       Province?    @relation(fields: [provinceId], references: [id])
  zone           Zone?        @relation(fields: [zoneId], references: [id])
  pointOfSale    PointOfSale? @relation(fields: [pointOfSaleId], references: [id])
  task           Task?        @relation(fields: [taskId], references: [id])
  visit          Visit?       @relation(fields: [visitId], references: [id])

  @@index([organizationId, dueDate])
  @@index([organizationId, status])
  @@index([ownerUserId, status])
}

model ExceptionRecord {
  id               String        @id
  organizationId   String
  type             String
  title            String
  description      String?
  submittedByUserId String
  reviewedByUserId String?
  taskId           String?
  visitId          String?
  mediaAssetId     String?
  consignationId   String?
  status           String
  submittedAt      String
  reviewedAt       String?
  reviewNote       String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  organization     Organization  @relation(fields: [organizationId], references: [id])
  submittedBy      User          @relation("ExceptionSubmittedBy", fields: [submittedByUserId], references: [id])
  reviewedBy       User?         @relation("ExceptionReviewedBy", fields: [reviewedByUserId], references: [id])
  task             Task?         @relation(fields: [taskId], references: [id])
  visit            Visit?        @relation(fields: [visitId], references: [id])
  mediaAsset       MediaAsset?   @relation(fields: [mediaAssetId], references: [id])
  consignation     Consignation? @relation(fields: [consignationId], references: [id])

  @@index([organizationId, status])
  @@index([organizationId, type])
  @@index([submittedByUserId, status])
}

model ReportSnapshot {
  id             String       @id
  organizationId String
  reportName     String
  locale         String
  fileName       String
  filtersJson    String
  rowCount       Int
  csvContent     String
  generatedAt    String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, reportName])
  @@index([organizationId, createdAt])
}

model ReminderRule {
  id             String       @id
  organizationId String
  name           String
  eventType      String
  channel        String
  offsetMinutes  Int
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, active])
}

model AdminSettings {
  organizationId        String       @id
  defaultRecipientEmails String
  retentionPhotoDays    Int
  retentionGpsDays      Int
  retentionAuditDays    Int
  updatedAt             DateTime     @updatedAt
  organization          Organization @relation(fields: [organizationId], references: [id])
}
