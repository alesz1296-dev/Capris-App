{
  "name": "@capris/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "db:generate": "prisma generate",
    "db:init": "prisma db execute --file prisma/init.sql --schema prisma/schema.prisma",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.cjs",
    "start": "node dist/apps/api/src/main.js",
    "start:dev": "nest start --watch --entryFile apps/api/src/main",
    "test:build": "npm --workspace @capris/shared run build && tsc -p tsconfig.test.json",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:build && node dist-test/tests/tasks.test.js && node dist-test/tests/visits.test.js && node dist-test/tests/evidence.test.js && node dist-test/tests/notes.test.js && node dist-test/tests/consignations.test.js && node dist-test/tests/auth.test.js && node dist-test/tests/object-storage.test.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@capris/shared": "*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/client": "^6.19.3",
    "prisma": "^6.19.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "jest": "^30.0.0",
    "typescript": "^5.8.0"
  }
}
